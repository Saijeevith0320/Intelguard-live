# IntelGuard production environment
ENVIRONMENT=production
AUTH_DISABLED=false
JWT_SECRET=replace-with-long-random-secret
CORS_ORIGINS=https://app.yourdomain.com,http://localhost:8000

# Optional Neo4j AuraDB / self-hosted Neo4j
NEO4J_URI=neo4j+s://your-neo4j.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-me

# AI provider
GEMINI_API_KEY=replace-me

# Hyperledger Fabric Gateway backend endpoint
FABRIC_GATEWAY_URL=https://fabric-gateway.yourdomain.com
FABRIC_CHANNEL=intelguard-channel
FABRIC_CHAINCODE=auditcc
FABRIC_FUNCTION=CreateAuditReceipt
FABRIC_MSP_ID=SCRBMSP
